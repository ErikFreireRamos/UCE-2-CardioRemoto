# ==== Ambiente ====
NODE_ENV=development

# Host/porta da API. HOST=0.0.0.0 é obrigatório para acesso pela rede local (testar no celular).
HOST=0.0.0.0
PORT=3000

# ==== Banco de dados (PostgreSQL) ====
# Dentro do docker-compose o host do Postgres é "postgres" (nome do serviço).
# Para rodar a API fora do contêiner apontando ao Postgres do compose, troque "postgres" por "localhost".
DATABASE_URL=postgresql://cardio:cardio@postgres:5432/cardioremoto?schema=public

# ==== JWT ====
JWT_ACCESS_SECRET=troque-este-segredo-de-access
JWT_REFRESH_SECRET=troque-este-segredo-de-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ==== CORS ====
# Lista separada por vírgula. Inclua a origem do frontend na rede local (IP do PC + porta do Vite).
# Descubra o IP do PC com "ipconfig" (Windows). Ex.: http://192.168.0.10:5173
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# ==== Regras de login (UC01 - fluxo alternativo) ====
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCK_MINUTES=15

# ==== Rate limit da rota de login ====
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_WINDOW_MINUTES=1

# ==== Credenciais do Postgres usadas pelo docker-compose ====
POSTGRES_USER=cardio
POSTGRES_PASSWORD=cardio
POSTGRES_DB=cardioremoto
